# Copy to .env.local. The single place to point the site at the Admin public API.
# This is a BUILD-TIME value (NEXT_PUBLIC_*): set it in your host (e.g. Vercel) and
# rebuild for it to take effect. If unset, prod builds default to admin.pyindore.com
# and dev to localhost:3001.
# Local dev: the admin runs on :3001.
# Production:  NEXT_PUBLIC_API_BASE_URL=https://admin.pyindore.com/api/v1/public
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1/public
